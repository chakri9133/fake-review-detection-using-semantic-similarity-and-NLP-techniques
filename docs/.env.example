# Environment Configuration for Fake Review Detection

# Backend Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True

# Server Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5000

# Frontend Configuration
FRONTEND_HOST=localhost
FRONTEND_PORT=5173

# Model Paths (Windows format)
MODEL_PATH=D:\Fake Review Detection\Models\logistic_model.joblib
MODEL_METRICS_PATH=D:\Fake Review Detection\Models\model_metrics.json

# SBERT Model
SBERT_MODEL=all-MiniLM-L6-v2

# API Configuration
API_TIMEOUT=30
CORS_ENABLED=True

# Logging
LOG_LEVEL=INFO

# Text Processing
TEXT_MIN_LENGTH=5
TEXT_MAX_LENGTH=5000

# Prediction Thresholds
THRESHOLD_GENUINE=0.30
THRESHOLD_FAKE=0.75
